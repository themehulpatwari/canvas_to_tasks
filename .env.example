# OAuth Configuration
OAUTH_CLIENT_ID=your_google_oauth_client_id
OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# Flask Configuration
FLASK_SECRET=random_secret_key
FLASK_PORT=3000
FLASK_ENV=production

# Encryption key for refresh tokens at rest (Fernet).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, refresh tokens are stored unencrypted (legacy behavior).
TOKEN_ENC_KEY=your_fernet_key

# MongoDB Configuration
# Full connection string from Atlas (Database > Connect > Drivers).
MONGO_URI=mongodb+srv://user:password@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
# Database (and Mongo collection) name to use within the cluster.
MONGO_DB_NAME=your_db_name
